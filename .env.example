# Supabase Postgres — pooled connection (pgbouncer, port 6543), used by the
# running app via the driver adapter in src/lib/prisma.ts.
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true"

# Supabase Postgres — direct connection (port 5432), used only by the Prisma
# CLI for migrations (see prisma.config.ts).
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# Seeded once by prisma/seed.ts into the AdminUser table (hashed there —
# nothing here is stored as plaintext).
ADMIN_EMAIL="admin@techstore.local"
ADMIN_PASSWORD=""

# Signs the admin session cookie (see step 2). Generate with:
# openssl rand -base64 32
ADMIN_SESSION_SECRET=""

# Stripe (added in step 5/6)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Supabase Storage — used by the admin image upload endpoint
# (src/app/api/admin/upload/route.ts). Same Supabase project as DATABASE_URL,
# just its Storage API instead of Postgres:
#   1. Dashboard -> Storage -> New bucket -> name it "images", set Public.
#   2. Dashboard -> Project Settings -> API -> copy "Project URL" and the
#      "service_role" secret key (NOT the anon/public key — this bypasses
#      Row Level Security so it must never be exposed to the client).
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
